# =============================================================================
# NL2SQL — konfiguracija okruženja
# =============================================================================
# Kopirajte ovaj file u `.env` i popunite vrijednosti. `.env` NIJE u gitu.

# -----------------------------------------------------------------------------
# Baza podataka
# -----------------------------------------------------------------------------
# Glavna konekcija — koristi se za migracije i schema inspection.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/chinook

# Read-only konekcija — koristi se za izvršavanje generiranih SQL upita.
# User `nl2sql_readonly` kreiran je u scripts/create_readonly_user.sql i
# ima samo GRANT SELECT. Ovo je glavni sigurnosni sloj na razini baze.
READONLY_DATABASE_URL=postgresql+asyncpg://nl2sql_readonly:readonly@postgres:5432/chinook

# -----------------------------------------------------------------------------
# LLM provider (anthropic | openai | ollama | gemini)
# -----------------------------------------------------------------------------
# Odaberi aktivnog providera. Za odabranog providera moraju biti popunjeni
# njegov API_KEY (ako nije lokalan) i MODEL.
LLM_PROVIDER=anthropic

# --- Anthropic Claude ---
# API ključ: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model: popuni s točnim imenom modela kojeg imaš pravo koristiti
# (provjeri u Anthropic Console — modeli se mijenjaju). Primjer formata:
# claude-<family>-<version>. Ostaviti prazno onemogućava ovog providera.
ANTHROPIC_MODEL=

# --- OpenAI ili OpenAI-kompatibilni servis ---
# Postavljanjem OPENAI_BASE_URL ovaj provider radi i za:
#   - OpenAI:        prazan OPENAI_BASE_URL (default)
#   - GitHub Models: OPENAI_BASE_URL=https://models.github.ai/inference
#                    OPENAI_API_KEY = tvoj GitHub PAT
#                    (https://github.com/settings/tokens — fine-grained, scope models:read)
#   - OpenRouter:    OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   - Groq:          OPENAI_BASE_URL=https://api.groq.com/openai/v1
#   - lokalni vllm:  OPENAI_BASE_URL=http://host.docker.internal:8000/v1
#
# Ovo radi jer svi navedeni servisi koriste OpenAI Chat Completions oblik API-ja.
OPENAI_API_KEY=
# Model: točan naziv kod tvog providera (npr. gpt-4o-mini za OpenAI,
# openai/gpt-4o za GitHub Models, llama-3.3-70b-versatile za Groq).
OPENAI_MODEL=
# Prazno = koristi službeni OpenAI endpoint. Postavi za alternativne providere.
OPENAI_BASE_URL=

# --- Google Gemini (free tier — preporučeno za besplatno testiranje) ---
# API ključ: https://aistudio.google.com/apikey (samo Google account, bez kartice)
# Free tier: ~15 zahtjeva/min, ~1500/dan, 1M tokena/min.
GEMINI_API_KEY=
# Model: provjeri https://ai.google.dev/gemini-api/docs/models i upiši točno ime.
# Primjeri: gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro.
GEMINI_MODEL=

# --- Ollama (lokalno, besplatno) ---
# Kada backend radi u Dockeru, host stroj je `host.docker.internal`
# (Windows/Mac); na Linuxu koristiti host IP ili dodati host.docker.internal
# u extra_hosts u docker-compose.yml.
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Model: prvo `ollama pull <name>` na hostu, zatim ovdje ime. Primjer:
# sqlcoder (SQL-specijaliziran), llama3, mistral. Ostaviti prazno onemogućava
# ovog providera.
OLLAMA_MODEL=

# -----------------------------------------------------------------------------
# Ponašanje sustava
# -----------------------------------------------------------------------------
# Timeout izvršavanja generiranog SQL upita (sekunde).
QUERY_TIMEOUT_SECONDS=10

# Default LIMIT koji se automatski dodaje ako ga LLM nije generirao —
# sprječava neograničeno velike rezultate.
DEFAULT_LIMIT=1000

# Koliko puta retry engine pokušava popraviti neispravan SQL.
MAX_RETRY_ATTEMPTS=2

# Kako dugo se shema baze drži u cacheu prije ponovnog dohvata.
SCHEMA_CACHE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# `json` za produkciju (strukturirano), `console` za razvoj (čitljivo).
LOG_FORMAT=console

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
